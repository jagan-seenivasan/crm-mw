{
  "name": "crm-server",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:staging": "cross-env NODE_ENV=staging ENV_FILE=.env.staging nodemon src/server.js",
    "start": "node src/server.js",
    "start:staging": "cross-env NODE_ENV=staging ENV_FILE=.env.staging node src/server.js",
    "start:prod": "cross-env NODE_ENV=production ENV_FILE=.env.production node src/server.js",
    "seed": "node scripts/seed.js",
    "fix:stage-indexes": "node scripts/fix-stage-indexes.js",
    "test": "node src/controllers/activityTimelineController.test.js && node src/controllers/opportunityController.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7"
  }
}
